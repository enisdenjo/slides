{
  "name": "slides",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "bun scripts/build.ts",
    "check:format": "prettier -c .",
    "check:spelling": "bunx --bun cspell slides/*.md",
    "check:types": "tsc --noEmit",
    "format": "bun check:format -w",
    "start": "slidev"
  },
  "dependencies": {
    "@iconify-json/grommet-icons": "^1.2.0",
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "^0.25.0",
    "@types/bun": "^1.3.13"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "cspell": "^10.0.0",
    "glob": "^13.0.6",
    "prettier": "^3.3.3",
    "prettier-plugin-pkg": "^0.22.1",
    "prettier-plugin-slidev": "^1.0.5",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
